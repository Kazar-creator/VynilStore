<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #0d0d0d;"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/25"
            fx:controller="VynilStore.EliminaController">

    <!-- HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #141414;
                     -fx-border-color: #c9a84c;
                     -fx-border-width: 0 0 1 0;
                     -fx-padding: 20 30 20 30;">
            <Button text="← Torna al catalogo" onAction="#handleTorna"
                    style="-fx-background-color: transparent; -fx-text-fill: #888888;
                           -fx-font-size: 11px; -fx-border-color: #2a2a2a;
                           -fx-border-width: 1; -fx-background-radius: 0;
                           -fx-padding: 8 14 8 14; -fx-cursor: hand;" />
            <Label text="🗑️  ELIMINA VINILE"
                   style="-fx-text-fill: #c0392b; -fx-font-size: 20px; -fx-font-weight: bold;" />
        </HBox>
    </top>

    <!-- SELEZIONE + ANTEPRIMA -->
    <center>
        <VBox alignment="TOP_CENTER" spacing="24"
              style="-fx-background-color: #0d0d0d;">
            <padding><Insets top="40" left="0" right="0" bottom="0" /></padding>

            <!-- Selezione vinile -->
            <HBox alignment="CENTER" spacing="12">
                <Label text="Seleziona vinile:"
                       style="-fx-text-fill: #888888; -fx-font-size: 12px;" />
                <ComboBox fx:id="sceltaVinile" promptText="— scegli —"
                          onAction="#handleSelezione"
                          style="-fx-background-color: #141414; -fx-font-size: 12px;
                                 -fx-border-color: #2a2a2a; -fx-pref-width: 300;" />
            </HBox>

            <!-- Anteprima vinile selezionato -->
            <VBox fx:id="anteprimaBox" visible="false" alignment="CENTER" spacing="8"
                  style="-fx-background-color: #141414;
                         -fx-border-color: #c0392b;
                         -fx-border-width: 1;
                         -fx-padding: 24;">

                <Label text="Stai per eliminare:" style="-fx-text-fill: #555555; -fx-font-size: 11px;" />
                <Label fx:id="titoloLabel" text=""
                       style="-fx-text-fill: #e0e0e0; -fx-font-size: 18px; -fx-font-weight: bold;" />
                <Label fx:id="artistaLabel" text=""
                       style="-fx-text-fill: #888888; -fx-font-size: 13px;" />
                <Label fx:id="dettagliLabel" text=""
                       style="-fx-text-fill: #555555; -fx-font-size: 11px;" />
                <Label fx:id="prezzoLabel" text=""
                       style="-fx-text-fill: #c9a84c; -fx-font-size: 14px; -fx-font-weight: bold;" />

                <Label text="⚠️  Questa operazione non può essere annullata."
                       style="-fx-text-fill: #c0392b; -fx-font-size: 11px; -fx-padding: 10 0 0 0;" />
            </VBox>
        </VBox>
    </center>

    <!-- BOTTONI -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="12"
              style="-fx-background-color: #141414;
                     -fx-border-color: #2a2a2a;
                     -fx-border-width: 1 0 0 0;
                     -fx-padding: 20 30 20 30;">
            <Button text="Annulla" onAction="#handleTorna"
                    style="-fx-background-color: transparent; -fx-text-fill: #888888;
                           -fx-font-size: 11px; -fx-border-color: #2a2a2a;
                           -fx-border-width: 1; -fx-background-radius: 0;
                           -fx-padding: 10 24 10 24; -fx-cursor: hand;" />
            <Button text="🗑️  Conferma eliminazione" onAction="#handleElimina"
                    style="-fx-background-color: #c0392b; -fx-text-fill: #ffffff;
                           -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-background-radius: 0; -fx-padding: 10 30 10 30; -fx-cursor: hand;" />
        </HBox>
    </bottom>

</BorderPane>
