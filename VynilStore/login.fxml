<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane style="-fx-background-color: #0d0d0d;"
           xmlns:fx="http://javafx.com/fxml/1"
           xmlns="http://javafx.com/javafx/25"
           fx:controller="VynilStore.LoginController">

    <!-- Testo decorativo background -->
    <Label text="VINYL"
           style="-fx-text-fill: #1a1a1a;
                  -fx-font-size: 110px;
                  -fx-font-weight: bold;" />

    <VBox alignment="CENTER" maxWidth="340" spacing="6"
          style="-fx-background-color: #141414;
                 -fx-border-color: #c9a84c;
                 -fx-border-width: 0 0 0 3;">

        <padding>
            <Insets bottom="40" left="36" right="36" top="20" />
        </padding>

        <!-- Logo -->
        <ImageView fitHeight="120" preserveRatio="true">
            <image>
                <Image url="@logoVero.png" />
            </image>
        </ImageView>

        <!-- Titolo con linea dorata sopra -->
        <VBox spacing="4">
            <Label text="VYNIL STORE"
                   style="-fx-text-fill: #c9a84c;
                          -fx-font-size: 20px;
                          -fx-font-weight: bold;" />
            <Label text="accedi alla tua collezione"
                   style="-fx-text-fill: #555555;
                          -fx-font-size: 11px;" />
        </VBox>

        <!-- Separatore -->
        <Label style="-fx-border-color: #2a2a2a;
                      -fx-border-width: 1 0 0 0;
                      -fx-pref-width: 9999;" />

        <!-- Campi -->
        <VBox spacing="14">
            <TextField fx:id="usernameField" promptText="USERNAME"
                       style="-fx-background-color: #0d0d0d;
                              -fx-text-fill: #e0e0e0;
                              -fx-prompt-text-fill: #444444;
                              -fx-background-radius: 0;
                              -fx-border-color: #2a2a2a;
                              -fx-border-width: 0 0 1 0;
                              -fx-border-radius: 0;
                              -fx-padding: 10 4 10 4;
                              -fx-font-size: 12px;" />

            <PasswordField fx:id="passwordField" promptText="PASSWORD"
                           style="-fx-background-color: #0d0d0d;
                                  -fx-text-fill: #e0e0e0;
                                  -fx-prompt-text-fill: #444444;
                                  -fx-background-radius: 0;
                                  -fx-border-color: #2a2a2a;
                                  -fx-border-width: 0 0 1 0;
                                  -fx-border-radius: 0;
                                  -fx-padding: 10 4 10 4;
                                  -fx-font-size: 12px;" />

            <Button fx:id="loginButton" maxWidth="Infinity"
                    onAction="#handleLogin"
                    text="ENTRA"
                    style="-fx-background-color: #c9a84c;
                           -fx-text-fill: #0d0d0d;
                           -fx-font-size: 12px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 0;
                           -fx-padding: 12 16 12 16;
                           -fx-cursor: hand;" />

            <Label fx:id="messageLabel"
                   style="-fx-text-fill: #c0392b;
                          -fx-font-size: 11px;"
                   text="" wrapText="true" />
        </VBox>

        <!-- Footer -->
        <Label text="© 2026 Vynil Store"
               style="-fx-text-fill: #2a2a2a;
                      -fx-font-size: 10px;" />

    </VBox>

</StackPane>